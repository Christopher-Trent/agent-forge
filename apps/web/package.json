    "@vitejs/plugin-react": "^4.6.0",
    "postprocessing": "^6.39.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.178.0",
    "vite": "^7.0.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.178.1",
    "typescript": "^5.8.3"
